# ToolNest Environment Variables
# Copy this file to .env.local and fill in your actual values

# --- Site URL (used in metadata, sitemap, canonical tags) ---
NEXT_PUBLIC_SITE_URL=https://toolnest.app

# --- Google AdSense ---
# Get this from your AdSense account after approval: https://www.google.com/adsense
# Format: ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-YOUR_ADSENSE_CLIENT_ID

# --- Google Search Console Verification ---
# Get this from Google Search Console > Settings > Ownership verification > HTML tag
GOOGLE_SITE_VERIFICATION=your-google-verification-code

# --- Google Analytics (optional) ---
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Contact Form Email Service (optional, for production contact form) ---
# If you wire up the Contact page to a real email service (Resend, SendGrid, etc.)
# RESEND_API_KEY=your-resend-api-key
# CONTACT_FORM_RECIPIENT=hadiazeem694@gmail.com
